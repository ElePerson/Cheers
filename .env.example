# AgentNexus 环境变量示例
# 复制为 .env 并填写实际值

# 数据库（主业务库 SQLite）
DATABASE_URL=sqlite+aiosqlite:///data/main.db

# Context Store 用 SQLite（四层记忆，独立文件）
SQLITE_CONTEXT_PATH=data/context_store/context.db

# Redis（Bot 响应队列等）
REDIS_URL=redis://localhost:6379/0

# 数据根目录（上传、转换、记忆 MD 等）
DATA_DIR=data

# 调试
DEBUG=false

# 系统 LLM（RECENT 压缩等，M2 可选；不配置则用简单截断）
# SYSTEM_LLM_API_KEY=
# SYSTEM_LLM_BASE_URL=https://api.openai.com/v1
# SYSTEM_LLM_MODEL=gpt-4o-mini
